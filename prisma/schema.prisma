generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model LogEntry {
  id         String   @id @default(cuid())
  date       DateTime
  learned    String
  built      String
  challenges String
  mood       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Skill {
  id        String         @id @default(cuid())
  name      String
  level     Int
  history   SkillHistory[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model SkillHistory {
  id        String   @id @default(cuid())
  skillId   String
  level     Int
  date      DateTime
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Milestone {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}