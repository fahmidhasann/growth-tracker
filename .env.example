# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Keep email/password as primary auth by default.
# Set to true only if you intentionally want Google OAuth enabled.
ENABLE_GOOGLE_OAUTH="false"

# Database connection string used by Prisma on Vercel and locally.
# On Vercel Postgres, this is usually injected automatically as POSTGRES_PRISMA_URL.
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional fallback if you use DATABASE_URL naming in other tooling.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
